#!/usr/bin/env sh
set -e

# GUI git clients (GitHub Desktop, etc.) often omit nvm/fnm/pnpm from PATH.
if ! command -v node >/dev/null 2>&1; then
  export NVM_DIR="${HOME}/.nvm"
  if [ -s "${NVM_DIR}/nvm.sh" ]; then
    . "${NVM_DIR}/nvm.sh"
  fi
  export PATH="${HOME}/.fnm/aliases/default/bin:/opt/homebrew/bin:/usr/local/bin:${PATH}"
fi

cd "$(dirname "$0")/.." || exit 1

if [ -x "./node_modules/.bin/lint-staged" ]; then
  ./node_modules/.bin/lint-staged
elif command -v pnpm >/dev/null 2>&1; then
  pnpm exec lint-staged
else
  echo "husky: lint-staged not found — run pnpm install" >&2
  exit 127
fi
