# Required — PostgreSQL connection string
# Encode special URL characters in the password (e.g. $ → %24)
DATABASE_URL=postgresql://postgres:password@localhost:5432/mathviz

# Required — JWT secrets, minimum 32 characters each
JWT_ACCESS_SECRET=change_me_to_a_random_string_of_at_least_32_chars
JWT_REFRESH_SECRET=change_me_to_a_different_random_string_of_at_least_32_chars

# Optional — bcrypt cost factor (default: 12)
BCRYPT_ROUNDS=12

# Optional — Express server port (default: 8080)
PORT=8080

# Required in production — allowed CORS origin for the frontend
FRONTEND_ORIGIN=http://localhost:3000

# Required — one of: development | production | test
NODE_ENV=development
